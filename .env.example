# MiMo Proxy Configuration
# Copy this file to .env and fill in your real API keys.

# MiMo (required for MiMo routing)
MIMO_API_KEY=sk-your-mimo-api-key
MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# MiMo Omni endpoint (optional, defaults to MIMO_BASE_URL)
MIMO_OMNI_BASE_URL=https://api.xiaomimimo.com/v1

# Claude / Anthropic (optional)
CLAUDE_API_KEY=sk-your-anthropic-key
CLAUDE_BASE_URL=https://api.anthropic.com

# Moonshot Kimi (optional)
KIMI_API_KEY=sk-your-kimi-key
KIMI_BASE_URL=https://api.moonshot.cn/v1

# Zhipu GLM (optional, used by video_analyze_kimi.py)
GLM_API_KEY=sk-your-glm-key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ModelScope (optional)
MODELSCOPE_API_TOKEN=your-modelscope-token
MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1

# Proxy server settings
PROXY_HOST=127.0.0.1
PROXY_PORT=8787
